{
    "name": "ducho/westech-rest-api",
    "description": "Product management REST API",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "symfony/http-foundation": "^7.2",
        "symfony/routing": "^7.2",
        "symfony/dependency-injection": "^7.2",
        "symfony/http-client": "^7.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ducho",
            "email": "dusan@schiffel.sk"
        }
    ],
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
